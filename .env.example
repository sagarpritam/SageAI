# ================================
# SageAI — Environment Variables
# Copy to .env and fill in values
# ================================

# ── Core ──────────────────────────────────────────
APP_NAME=SageAI Security Scanner
ENV=development                          # development | production
DEBUG=true

# ── Database ──────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite+aiosqlite:///./sageai.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://sageai:password@localhost:5432/sageai
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Authentication ────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────
# Comma-separated origins (use * only for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT=60/minute

# ── AI (optional) ─────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── OSINT (optional) ──────────────────────────────
# VIRUSTOTAL_API_KEY=your-free-key-from-virustotal.com

# ── Email (optional) ──────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=noreply@yourdomain.com

# ── Stripe Billing (optional) ─────────────────────
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Integrations (optional) ───────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# JIRA_URL=https://yoursite.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=...
# JIRA_PROJECT_KEY=SEC

# ── Error Tracking (optional) ─────────────────────
# SENTRY_DSN=https://...@sentry.io/...
